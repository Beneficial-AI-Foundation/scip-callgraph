# Use for remote deployment (EC2 behind reverse proxy at /graph/)
# VITE_MODE=remote
# VITE_ORIGIN=http://your-domain.com

# Port for dev server (default: 3000 local, 3001 remote)
# Set when port 3001 is taken (e.g. by the reverse proxy)
# VITE_PORT=3002

# Optional: default graph JSON URL
# VITE_GRAPH_JSON_URL=https://example.com/graph.json
