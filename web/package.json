{
  "name": "scip-callgraph-viewer",
  "version": "1.0.0",
  "description": "Interactive D3.js visualization for SCIP call graphs",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:remote": "VITE_MODE=remote tsc && vite build",
    "build:vscode": "tsc && vite build --config vite.config.vscode.js",
    "dev": "vite",
    "dev:remote": "VITE_MODE=remote vite",
    "preview": "vite preview",
    "preview:remote": "VITE_MODE=remote vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "d3": "^7.9.0",
    "d3-force": "^3.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/d3": "^7.4.3",
    "playwright": "^1.58.2",
    "typescript": "^5.6.3",
    "vite": "^4.5.2",
    "vitest": "^1.6.0"
  }
}
